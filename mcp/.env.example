# wrighting MCP 서버 환경변수
# Supabase 프로젝트 설정 > API 에서 확인.

# Supabase 프로젝트 URL (앱의 VITE_SUPABASE_URL 과 동일)
WRIGHTING_SUPABASE_URL=https://xxxxxxxx.supabase.co

# Service role key (RLS 우회 — 절대 외부 공유 금지, 이 .env 는 커밋되지 않음)
WRIGHTING_SUPABASE_SERVICE_KEY=eyJhbGciOi...

# 소유자 auth.users.id — 공용 하네스·프로젝트 목록을 이 사용자로 한정.
# create_project 등 소유자 도장이 필요한 쓰기에는 필수. 단일 사용자도 설정 권장.
WRIGHTING_OWNER_ID=

# (선택) 작품 매핑 — 이 MCP 인스턴스가 기본으로 가리킬 작품.
# 보통 각 소설 폴더의 .mcp.json 에서 해당 작품으로 지정한다.
# 도구 호출 시 projectId/project 를 생략하면 이 값으로 해석된다.
WRIGHTING_PROJECT_ID=
# 또는 제목으로 (부분 일치). ID 가 우선.
WRIGHTING_PROJECT=

# (선택) Gemini API 키 — RAG 의미검색(search mode=semantic)·reindex 에 필요.
# 없으면 search 는 키워드(ILIKE)로만 동작한다. https://aistudio.google.com/apikey
GEMINI_API_KEY=
