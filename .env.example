# Supabase 연결 정보 (.env 로 복사해서 채우세요)
# 로컬 개발: `supabase start` 출력의 API URL / anon key 사용
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-anon-key

# 공유 링크 공개 뷰어의 기준 URL (배포 도메인). 공개 페이지는 후속 단계.
VITE_SHARE_BASE_URL=https://wrighting.vercel.app

# MCP 서버 배포/로컬 실행 설정
PORT=8787
MCP_HOST=0.0.0.0
MCP_ALLOWED_ORIGIN=*
